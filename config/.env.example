# Jenkins
JENKINS_BASE_URL=http://your-jenkins
JENKINS_USER=admin
JENKINS_TOKEN=

# GitLab
GITLAB_BASE_URL=http://your-gitlab
GITLAB_TOKEN=

# Gitee
GITEE_BASE_URL=https://gitee.com/api/v5
GITEE_TOKEN=

# Gitea
GITEA_BASE_URL=
GITEA_TOKEN=

# GitHub
GITHUB_BASE_URL=https://api.github.com
GITHUB_TOKEN=

# Harbor
HARBOR_BASE_URL=http://your-harbor
HARBOR_USER=admin
HARBOR_PASSWORD=

# Git（URL 无法识别时的默认平台，自建 GitLab/Gitea 必填）
DEFAULT_GIT_PLATFORM=gitlab

# 管理后台登录
ADMIN_USER=admin
ADMIN_PASSWORD=

# Build 模式：jenkins | gitlab_ci | both (共存模式:包含jenkins和gitlab_ci)
BUILD_MODE=both

# App
APP_ENV=production
APP_DEBUG=false
BUILD_TIMEOUT=300
LOG_PATH=/data/logs/ci-platform/