{
  "openapi": "3.0.3",
  "info": {
    "title": "Devops-Glue API",
    "version": "2.3",
    "description": "DevOps 工具链集成接口 —— Jenkins、GitLab/Gitee/GitHub/Gitea、Harbor 一键集成与数据互通。",
    "contact": {
      "email": "jeanslw@qq.com"
    }
  },
  "servers": [
    {
      "url": "",
      "description": "测试环境"
    }
  ],
  "tags": [
    {
      "name": "Main",
      "description": "概览与映射"
    },
    {
      "name": "Jenkins",
      "description": "构建、状态与日志"
    },
    {
      "name": "Git",
      "description": "代码仓库分支"
    },
    {
      "name": "Harbor",
      "description": "镜像仓库与扫描"
    },
    {
      "name": "Health",
      "description": "健康检查"
    },
    {
      "name": "Admin",
      "description": "管理后台 —— 映射配置与对接版本"
    }
  ],
  "components": {
    "parameters": {
      "format": {
        "name": "format",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "raw",
            "json",
            "xml"
          ],
          "default": "raw"
        },
        "description": "输出格式：raw（默认）/ json / xml"
      }
    },
    "responses": {
      "400": {
        "description": "参数错误",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "404": {
        "description": "资源不存在",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "500": {
        "description": "服务端错误",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 400
          },
          "message": {
            "type": "string",
            "example": "错误描述"
          }
        }
      },
      "BuildTriggerResult": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "构建触发成功"
          },
          "job": {
            "type": "string",
            "example": "php/myapp"
          },
          "triggered_params": {
            "type": "object",
            "example": {
              "branches": "main",
              "zone": "test"
            }
          },
          "queue_id": {
            "type": "string",
            "example": "114"
          },
          "queue_url": {
            "type": "string",
            "example": "http://URL/queue/item/114/"
          }
        }
      },
      "HealthResult": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "checks": {
            "type": "object",
            "properties": {
              "jenkins": {
                "type": "boolean"
              },
              "jenkins_version": {
                "type": "string",
                "example": "2.555.3",
                "description": "Jenkins 版本号（可连通时返回）"
              },
              "git": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "api_version": {
                      "type": "string",
                      "example": "v4"
                    },
                    "reachable": {
                      "type": "boolean"
                    }
                  }
                },
                "nullable": true,
                "description": "null 表示未配置 Git 平台"
              },
              "harbor": {
                "type": "boolean",
                "nullable": true
              },
              "harbor_version": {
                "type": "string",
                "example": "v2",
                "description": "Harbor API 版本号"
              }
            }
          },
          "app_env": {
            "type": "string",
            "example": "production"
          },
          "time": {
            "type": "string",
            "example": "2026-07-05 12:00:00"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["user", "password"],
        "properties": {
          "user": { "type": "string", "example": "admin" },
          "password": { "type": "string", "example": "admin123" }
        }
      },
      "LoginResult": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "example": "YWRtaW46YWRtaW4xMjM=", "description": "Bearer token，后续请求通过 Authorization header 传递" }
        }
      },
      "JobGitMapEntry": {
        "type": "object",
        "required": ["job_name"],
        "properties": {
          "job_name": { "type": "string", "description": "Jenkins Job 完整路径，必填", "example": "php/myapp" },
          "git_platform": { "type": "string", "description": "目标 Git 平台名", "example": "gitlab" },
          "git_remote": { "type": "string", "description": "Git 仓库远程地址", "example": "http://git.company.com/project.git" },
          "project_id": { "type": "integer", "nullable": true, "description": "Git 项目 ID（GitLab 不填自动查询）", "example": 5 },
          "web_url": { "type": "string", "description": "项目主页链接", "example": "http://git.company.com/project" },
          "current_path": { "type": "string", "description": "项目路径", "example": "tools/registry" },
          "harbor_repository": { "type": "string", "description": "关联 Harbor 仓库", "example": "mycode/myapp" },
          "api_version": { "type": "string", "description": "平台 API 版本（纯元数据）" }
        }
      },
      "MapListResult": {
        "type": "object",
        "description": "按项目路径分组的映射关系。Jenkins 不可达且有过期缓存时附加 _stale=true",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "git_platform": { "type": "string" },
            "git_remote": { "type": "string" },
            "project_id": { "type": "integer", "nullable": true },
            "web_url": { "type": "string" },
            "harbor_repository": { "type": "string" },
            "platform_source": { "type": "string", "enum": ["auto", "manual"] },
            "detection_method": { "type": "string", "enum": ["exact", "fallback", "manual"] },
            "jobs": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "PlatformVersionsResult": {
        "type": "object",
        "properties": {
          "versions": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "value": { "type": "string", "example": "v4" },
                "source": { "type": "string", "enum": ["config", "json", "default"], "description": "config=settings.php | json=管理界面 | default=系统默认" }
              }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "健康检查",
        "operationId": "health",
        "parameters": [
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "正常",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResult"
                }
              }
            }
          },
          "503": {
            "description": "服务降级"
          }
        }
      }
    },
    "/api/main/jobs/list": {
      "get": {
        "tags": [
          "Main"
        ],
        "summary": "获取所有 Job 列表",
        "operationId": "jobsList",
        "parameters": [
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "Job 名称数组",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/main/map/list": {
      "get": {
        "tags": [
          "Main"
        ],
        "summary": "Job / Git / Harbor 三方映射",
        "description": "按项目分组返回 Jenkins Job 与 Git 仓库、Harbor 镜像的映射关系。内置 30s 缓存，Jenkins 不可达时返回过期数据（附带 _stale 标记）",
        "operationId": "mapList",
        "parameters": [
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "分组映射 JSON 对象",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MapListResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/main/git/platforms": {
      "get": {
        "tags": [
          "Main"
        ],
        "summary": "已接入的 Git 平台列表",
        "description": "返回静态配置的 Git 平台和 Harbor API 信息",
        "operationId": "gitPlatforms",
        "parameters": [
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "平台配置 JSON"
          }
        }
      }
    },
    "/api/main/git/discovery": {
      "get": {
        "tags": [
          "Main"
        ],
        "summary": "平台接入检测",
        "description": "对比实际使用的 Git 平台与配置，返回已配置和未配置的平台列表",
        "operationId": "gitDiscovery",
        "parameters": [
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "configured / unconfigured 列表"
          }
        }
      }
    },
    "/api/admin/login": {
      "post": {
        "tags": ["Admin"],
        "summary": "管理后台登录",
        "description": "使用 .env 中 ADMIN_USER / ADMIN_PASSWORD 验证，返回 Bearer token",
        "operationId": "adminLogin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginResult" } } }
          },
          "401": {
            "description": "账号或密码错误",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/api/admin/job_git_map": {
      "get": {
        "tags": ["Admin"],
        "summary": "列出所有 Job-Git 映射",
        "operationId": "adminMapList",
        "security": [{ "bearerAuth": [] }],
        "parameters": [ { "$ref": "#/components/parameters/format" } ],
        "responses": {
          "200": {
            "description": "映射列表 + 可用平台",
            "content": { "application/json": { "schema": { "type": "object", "properties": {
              "maps": { "type": "array", "items": { "$ref": "#/components/schemas/JobGitMapEntry" } },
              "platforms": { "type": "array", "items": { "type": "string" } }
            } } } }
          },
          "401": { "$ref": "#/components/responses/400" }
        }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "新增一条映射",
        "operationId": "adminMapCreate",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/JobGitMapEntry" } } }
        },
        "responses": {
          "200": { "description": "新增成功" },
          "400": { "$ref": "#/components/responses/400" },
          "409": { "description": "job_name 已存在" }
        }
      },
      "put": {
        "tags": ["Admin"],
        "summary": "更新一条映射（按 _original_job_name 匹配）",
        "operationId": "adminMapUpdate",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "allOf": [
            { "$ref": "#/components/schemas/JobGitMapEntry" },
            { "type": "object", "properties": { "_original_job_name": { "type": "string", "description": "修改前的 job_name" } }, "required": ["_original_job_name"] }
          ] } } }
        },
        "responses": {
          "200": { "description": "更新成功" },
          "404": { "$ref": "#/components/responses/404" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "删除一条映射",
        "operationId": "adminMapDelete",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "job_name", "in": "query", "required": true, "schema": { "type": "string" }, "description": "要删除的 Job 名称" }
        ],
        "responses": {
          "200": { "description": "删除成功" },
          "404": { "$ref": "#/components/responses/404" }
        }
      }
    },
    "/api/admin/platform_versions": {
      "get": {
        "tags": ["Admin"],
        "summary": "获取平台对接版本",
        "description": "返回各平台 API 版本号及来源（config=配置文件 / json=管理界面 / default=系统默认）",
        "operationId": "adminVersionsList",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "版本信息",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PlatformVersionsResult" } } }
          }
        }
      },
      "put": {
        "tags": ["Admin"],
        "summary": "更新平台对接版本",
        "description": "传入 { versions: { gitlab: v5, ... } }，与默认值相同的项不保存",
        "operationId": "adminVersionsUpdate",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": {
            "versions": { "type": "object", "description": "平台名→版本号映射", "example": { "gitlab": "v4", "harbor": "v2.0" } }
          }, "required": ["versions"] } } }
        },
        "responses": {
          "200": { "description": "更新成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PlatformVersionsResult" } } } }
        }
      }
    },
    "/api/jenkins/{job}/build_trigger": {
      "post": {
        "tags": [
          "Jenkins"
        ],
        "summary": "触发构建",
        "description": "通过 Query String 传入构建参数。Job 必须恰好有 1 或 2 个参数（通常为 branch / zone）",
        "operationId": "buildTrigger",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Job 路径，支持 1-2 层（如 static、php/myapp）",
            "example": "php/myapp",
            "allowReserved": true
          },
          {
            "name": "branches",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "分支名",
            "example": "main"
          },
          {
            "name": "zone",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "部署区域（双参数 Job 用）",
            "example": "test"
          }
        ],
        "responses": {
          "200": {
            "description": "触发成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BuildTriggerResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        }
      }
    },
    "/api/jenkins/{job}/parameters": {
      "get": {
        "tags": [
          "Jenkins"
        ],
        "summary": "查询构建参数（当前定义）",
        "description": "返回当前 Job 的所有参数名及其可选值",
        "operationId": "parameters",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Job 路径",
            "example": "php/myapp",
            "allowReserved": true
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "参数名: 选项数组",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/404"
          }
        }
      }
    },
    "/api/jenkins/{job}/0/parameters": {
      "get": {
        "tags": [
          "Jenkins"
        ],
        "summary": "查询最新构建的参数名列表",
        "description": "build_id=0 表示取最新一次构建中用到的参数名",
        "operationId": "parametersLatest",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "php/myapp",
            "allowReserved": true
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "参数名数组",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/jenkins/{job}/{buildId}/parameters": {
      "get": {
        "tags": [
          "Jenkins"
        ],
        "summary": "查询指定历史构建的参数名列表",
        "operationId": "parametersHistory",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "php/myapp",
            "allowReserved": true
          },
          {
            "name": "buildId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "构建编号（>0）",
            "example": 14
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "参数名数组",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/jenkins/{job}/build_id": {
      "get": {
        "tags": [
          "Jenkins"
        ],
        "summary": "构建 ID 列表",
        "operationId": "buildIdList",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "php/myapp",
            "allowReserved": true
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "构建 ID 数组",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/jenkins/{job}/build_time": {
      "get": {
        "tags": [
          "Jenkins"
        ],
        "summary": "成功构建列表（带时间）",
        "operationId": "buildTimeList",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "php/myapp",
            "allowReserved": true
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "格式: #ID [Y-m-d H:i:s]",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/jenkins/{job}/build": {
      "get": {
        "tags": [
          "Jenkins"
        ],
        "summary": "成功构建列表（带 # 号）",
        "operationId": "buildList",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "php/myapp",
            "allowReserved": true
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "格式: #ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/jenkins/{job}/{buildId}/status": {
      "get": {
        "tags": [
          "Jenkins"
        ],
        "summary": "查询构建状态",
        "operationId": "buildStatus",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "php/myapp",
            "allowReserved": true
          },
          {
            "name": "buildId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "example": 14
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "SUCCESS / FAILURE / ABORTED / UNSTABLE",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/jenkins/{job}/{buildId}/console": {
      "get": {
        "tags": [
          "Jenkins"
        ],
        "summary": "控制台日志",
        "description": "返回纯文本控制台输出，不受 format 参数影响",
        "operationId": "console",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "php/myapp",
            "allowReserved": true
          },
          {
            "name": "buildId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "example": 14
          }
        ],
        "responses": {
          "200": {
            "description": "控制台日志（text/plain）",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/git/{job}/branches": {
      "get": {
        "tags": [
          "Git"
        ],
        "summary": "查询 Job 对应的 Git 分支列表",
        "description": "等同于 /api/jenkins/{job}/branches",
        "operationId": "gitBranches",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "php/myapp",
            "allowReserved": true
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "分支名数组",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/404"
          }
        }
      }
    },
    "/api/harbor/projects": {
      "get": {
        "tags": [
          "Harbor"
        ],
        "summary": "获取项目列表",
        "operationId": "harborProjects",
