          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "项目名数组",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/500"
          }
        }
      }
    },
    "/api/harbor/{project}/repositories": {
      "get": {
        "tags": [
          "Harbor"
        ],
        "summary": "获取仓库列表",
        "operationId": "harborRepositories",
        "parameters": [
          {
            "name": "project",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "mycode"
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "仓库名数组（已去项目前缀）",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/harbor/{project}/repositories/{repository}/tags": {
      "get": {
        "tags": [
          "Harbor"
        ],
        "summary": "获取 Tag 列表",
        "description": "仓库名如含 / 需双重编码（%2F）",
        "operationId": "harborTags",
        "parameters": [
          {
            "name": "project",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "mycode"
          },
          {
            "name": "repository",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "diagnosis-runtime",
            "allowReserved": true
          },
          {
            "$ref": "#/components/parameters/format"
          }
        ],
        "responses": {
          "200": {
            "description": "Tag 名数组",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/harbor/{project}/repositories/{repository}/tags/{tag}/scan": {
      "post": {
        "tags": [
          "Harbor"
        ],
        "summary": "触发镜像扫描",
        "operationId": "harborScanTrigger",
        "parameters": [
          {
            "name": "project",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "mycode"
          },
          {
            "name": "repository",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "diagnosis-runtime",
            "allowReserved": true
          },
          {
            "name": "tag",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "v1.0.0"
          }
        ],
        "responses": {
          "200": {
            "description": "扫描已触发",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "扫描功能未启用",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Harbor"
        ],
        "summary": "获取扫描报告",
        "operationId": "harborScanReport",
        "parameters": [
          {
            "name": "project",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "mycode"
          },
          {
            "name": "repository",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "diagnosis-runtime",
            "allowReserved": true
          },
          {
            "name": "tag",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "v1.0.0"
          }
        ],
        "responses": {
          "200": {
            "description": "漏洞报告 JSON 数组，无漏洞时为空数组"
          },
          "503": {
            "description": "扫描功能未启用"
          }
        }
      }
    }
  }
}
